From 86a3adbf452800942e985e21f0fb55caf6da5f07 Mon Sep 17 00:00:00 2001
From: covidisahoax <OothecaPickle@users.noreply.github.com>
Date: Mon, 30 Sep 2024 18:22:56 -0700
Subject: [PATCH] the request when checking the secret now requires the
 X-User-Auth-Token header

---
 streamrip/client/qobuz.py | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/streamrip/client/qobuz.py b/streamrip/client/qobuz.py
index b9bf152..8d07f5c 100644
--- a/streamrip/client/qobuz.py
+++ b/streamrip/client/qobuz.py
@@ -163,7 +163,6 @@ class QobuzClient(Client):
             f.set_modified()
 
         self.session.headers.update({"X-App-Id": c.app_id})
-        self.secret = await self._get_valid_secret(c.secrets)
 
         if c.use_auth_token:
             params = {
@@ -195,6 +194,8 @@ class QobuzClient(Client):
         uat = resp["user_auth_token"]
         self.session.headers.update({"X-User-Auth-Token": uat})
 
+        self.secret = await self._get_valid_secret(c.secrets)
+
         self.logged_in = True
 
     async def get_metadata(self, item_id: str, media_type: str):
-- 
2.46.0

